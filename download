"""
models.py - Shared database access layer
Both admin_app and user_app import from here.
Single source of truth for all DB operations.
"""

import os
import sqlite3
import secrets
from datetime import datetime, timedelta
from flask import g

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH  = os.path.join(BASE_DIR, 'database', 'quickdealr.db')
SCHEMA   = os.path.join(BASE_DIR, 'database', 'schema.sql')

#  Connection 

def get_db():
    """Get a per-request DB connection stored in Flask's g object."""
    if 'db' not in g:
        g.db = sqlite3.connect(DB_PATH)
        g.db.row_factory = sqlite3.Row
        g.db.execute("PRAGMA foreign_keys = ON")
        g.db.execute("PRAGMA journal_mode = WAL")
    return g.db


def close_db(e=None):
    db = g.pop('db', None)
    if db:
        db.close()


def get_raw_conn():
    """Get a plain connection outside of request context (e.g., SocketIO handlers)."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    conn.execute("PRAGMA journal_mode = WAL")
    return conn


def init_db():
    """Create all tables from schema and seed admin account."""
    from werkzeug.security import generate_password_hash
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    with open(SCHEMA, encoding='utf-8') as f:
        conn.executescript(f.read())

    #  Migrations: safe ALTER TABLE for missing columns 
    def _migrate(table, col, definition):
        cols = [r[1] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()]
        if col not in cols:
            conn.execute(f"ALTER TABLE {table} ADD COLUMN {col} {definition}")
            conn.commit()
            print(f"[DB] Migrated: {table}.{col}")

    _migrate('products', 'status', "TEXT NOT NULL DEFAULT 'pending'")
    conn.execute("UPDATE products SET status='approved' WHERE approved=1 AND status='pending'")
    conn.commit()

    try:
        conn.execute(
            "INSERT OR IGNORE INTO users (username,password,role,email,wallet) VALUES (?,?,?,?,?)",
            ('admin', generate_password_hash('admin123'), 'admin', 'admin@quickdealr.com', 0.0))
    except Exception:
        pass
    conn.commit()
    conn.close()
    print("[DB] Initialized:", DB_PATH)


