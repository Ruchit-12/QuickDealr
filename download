    db.commit()


def toggle_user_active(uid):
    db = get_db()
    user = db.execute("SELECT is_active FROM users WHERE id=?", (uid,)).fetchone()
    if user:
        new_state = 0 if user['is_active'] else 1
        db.execute("UPDATE users SET is_active=? WHERE id=?", (new_state, uid))
        db.commit()
        return new_state
    return None


def toggle_user_whitelist(uid):
    """Toggle is_whitelisted for a user. Creates the column if it doesn't exist yet."""
    db = get_db()
    # Ensure column exists (migration-safe)
    try:
        db.execute("SELECT is_whitelisted FROM users LIMIT 1")
    except Exception:
        db.execute("ALTER TABLE users ADD COLUMN is_whitelisted INTEGER NOT NULL DEFAULT 0")
        db.commit()
    user = db.execute("SELECT is_whitelisted FROM users WHERE id=?", (uid,)).fetchone()
    if user is None:
        return None
    new_state = 0 if user['is_whitelisted'] else 1
    db.execute("UPDATE users SET is_whitelisted=? WHERE id=?", (new_state, uid))
    db.commit()
    return new_state


