def place_bid(product_id, user_id, username, amount, ip_address):
    """
    Place a bid. No wallet balance check — any user can bid any amount.
    Payment is collected after auction ends from the highest bidder.
    """
    db = get_db()
    prev = db.execute(
        "SELECT highest_bidder, highest_bid_uid, bid_count FROM products WHERE id=?",
        (product_id,)).fetchone()
    db.execute(
        "INSERT INTO bids (product_id,user_id,username,amount,ip_address) VALUES (?,?,?,?,?)",
        (product_id, user_id, username, amount, ip_address))
    db.execute(
        "UPDATE products SET current_bid=?,bid_count=bid_count+1,highest_bidder=?,highest_bid_uid=? WHERE id=?",
        (amount, username, user_id, product_id))
    db.commit()
    return prev


