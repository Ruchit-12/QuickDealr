def check_bid_rate(user_id, product_id, ip, cooldown=5, window=10, max_bids=3, block_min=15):
    db = get_db()
    if db.execute(
        "SELECT id FROM blocked_ips WHERE ip_address=? AND "
        "(expires_at IS NULL OR expires_at > CURRENT_TIMESTAMP)", (ip,)).fetchone():
        return False, 'Your IP is temporarily blocked.'
    now          = datetime.now()
    cooldown_cut = (now - timedelta(seconds=cooldown)).strftime('%Y-%m-%d %H:%M:%S')
    window_cut   = (now - timedelta(seconds=window)).strftime('%Y-%m-%d %H:%M:%S')
    if db.execute(
        "SELECT id FROM bid_rate_log WHERE user_id=? AND product_id=? AND created_at>? LIMIT 1",
        (user_id, product_id, cooldown_cut)).fetchone():
        return False, f'Wait {cooldown}s between bids.'
    n = db.execute(
        "SELECT COUNT(*) as n FROM bid_rate_log WHERE user_id=? AND created_at>?",
        (user_id, window_cut)).fetchone()['n']
    if n >= max_bids:
        exp = (now + timedelta(minutes=block_min)).strftime('%Y-%m-%d %H:%M:%S')
        try:
            db.execute("INSERT OR REPLACE INTO blocked_ips (ip_address,reason,expires_at) VALUES (?,?,?)",
                       (ip, 'Automated bidding detected', exp))
            db.commit()
        except Exception:
            pass
        return False, 'Suspicious activity. Temporarily blocked.'
    return True, 'OK'


