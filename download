def get_all_users():
    db = get_db()
    # Ensure is_whitelisted column exists (safe migration)
    try:
        db.execute("SELECT is_whitelisted FROM users LIMIT 1")
    except Exception:
        db.execute("ALTER TABLE users ADD COLUMN is_whitelisted INTEGER NOT NULL DEFAULT 0")
        db.commit()
    return db.execute("SELECT * FROM users ORDER BY created_at DESC").fetchall()


def create_user(username, password_hash, email, role, wallet=0.0):
    db = get_db()
