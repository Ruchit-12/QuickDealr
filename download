def process_auction_payment(product_id, user_id):
    """
    Called when a winner pays. Deducts wallet, marks as paid.
    Returns (success, message).
    """
    db  = get_db()
    win = db.execute(
        "SELECT * FROM auction_winners WHERE product_id=? AND winner_user_id=? AND status='pending_payment'",
        (product_id, user_id)).fetchone()
    if not win:
        return False, "No pending payment found for you on this auction."

    balance = get_wallet(user_id)
    if balance < win['bid_amount']:
        return False, f"Insufficient wallet balance (Rs.{balance:.2f}). Please top up first."

    # Deduct from wallet
    deduct_wallet(user_id, win['bid_amount'],
                  f"Auction payment for product #{product_id}",
                  method='auction')

    # Mark as paid
    db.execute(
        "UPDATE auction_winners SET status='paid', paid_at=CURRENT_TIMESTAMP WHERE id=?",
        (win['id'],))
    db.commit()

    add_notification(user_id,
                     f"Payment of Rs.{win['bid_amount']:.2f} confirmed. Auction item will be delivered soon.",
                     ntype='info')
    return True, "Payment successful!"


def trigger_failover(product_id):
    """
    If the current rank-1 winner fails to pay within the deadline,
    move them to 'failed' and promote the next bidder.
    Returns the new winner row or None if no more candidates.
    """
    db  = get_db()
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

    # Find expired unpaid winner
    expired = db.execute(
        "SELECT * FROM auction_winners WHERE product_id=? AND status='pending_payment' "
        "AND payment_deadline < ?",
        (product_id, now)).fetchone()
    if not expired:
        return None  # no expired winner

    # Mark as failed
    db.execute("UPDATE auction_winners SET status='failed' WHERE id=?", (expired['id'],))

    # Find next candidate (lowest rank that is still 'skipped')
    next_w = db.execute(
        "SELECT * FROM auction_winners WHERE product_id=? AND status='skipped' "
        "ORDER BY rank ASC LIMIT 1",
        (product_id,)).fetchone()

    if not next_w:
        db.commit()
        return None  # no more candidates

    # Assign payment deadline to next winner
    new_deadline = (datetime.now() + timedelta(hours=AUCTION_PAYMENT_HOURS)).strftime('%Y-%m-%d %H:%M:%S')
    db.execute(
        "UPDATE auction_winners SET status='pending_payment', payment_deadline=? WHERE id=?",
        (new_deadline, next_w['id']))
    db.commit()

    add_notification(
        next_w['winner_user_id'],
        f"You are now the winner of the auction! Please pay Rs.{next_w['bid_amount']:.2f} within {AUCTION_PAYMENT_HOURS} hours.",
        ntype='info')

    return next_w


