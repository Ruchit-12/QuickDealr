#  Sessions 

def create_session_token(user_id, ip_address):
    token   = secrets.token_hex(32)
    expires = (datetime.now() + timedelta(days=7)).strftime('%Y-%m-%d %H:%M:%S')
    db = get_db()
    db.execute("UPDATE sessions SET is_valid=0 WHERE user_id=?", (user_id,))
    db.execute(
        "INSERT INTO sessions (user_id,token,ip_address,expires_at) VALUES (?,?,?,?)",
        (user_id, token, ip_address, expires))
    db.execute("UPDATE users SET session_token=? WHERE id=?", (token, user_id))
    db.commit()
    return token


def invalidate_session(user_id, token):
    db = get_db()
    db.execute("UPDATE sessions SET is_valid=0 WHERE user_id=? AND token=?", (user_id, token))
    db.execute("UPDATE users SET session_token=NULL WHERE id=?", (user_id,))
    db.commit()


def valid_session(user_id, token):
    if not token:
        return False
    row = get_db().execute(
        "SELECT id FROM sessions WHERE user_id=? AND token=? AND is_valid=1 "
        "AND expires_at > CURRENT_TIMESTAMP", (user_id, token)).fetchone()
    return row is not None


